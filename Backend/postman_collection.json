        {
          "name": "Create Event (Organizer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"eventId\", jsonData.eventId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{organizerJwtToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Summer Music Festival",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "A fantastic music festival with top artists.",
                  "type": "text"
                },
                {
                  "key": "location",
                  "value": "Pune",
                  "type": "text"
                },
                {
                  "key": "event_date",
                  "value": "2026-07-20",
                  "type": "text"
                },
                {
                  "key": "event_time",
                  "value": "18:00:00",
                  "type": "text"
                },
                {
                  "key": "category_id",
                  "value": "{{categoryId}}",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "50.00",
                  "type": "text"
                },
                {
                  "key": "capacity",
                  "value": "1000",
                  "type": "text"
                },
                {
                  "key": "banner_image",
                  "type": "file",
                  "src": "/path/to/your/image.jpg",
                  "enabled": false
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events?page=1&limit=10&category=Music",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "category",
                  "value": "Music"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Event",
          "request": {
            "method": "GET",
            "header": [],
