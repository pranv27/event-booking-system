          "name": "Update Event (Organizer)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{organizerJwtToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Updated Summer Music Festival",
                  "type": "text"
                },
                {
                  "key": "capacity",
                  "value": "1200",
                  "type": "text"
                },
                {
                  "key": "banner_image",
