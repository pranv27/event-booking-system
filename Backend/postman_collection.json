            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "{{eventId}}",
                "status"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Event (Organizer)",
